# Runtime
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=camstore_root_2026
DB_SYNC=true
DB_SYNC_ALTER=false
SEED_PRODUCTS_ON_EMPTY=true

# Database-per-service
USER_DB_NAME=user_db
PRODUCT_DB_NAME=product_db
CART_DB_NAME=cart_db
ORDER_DB_NAME=order_db
PAYMENT_DB_NAME=payment_db
REVIEW_DB_NAME=review_db
BLOG_DB_NAME=blog_db
NOTIFICATION_DB_NAME=notification_db

# Service ports
API_GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
CART_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004
PAYMENT_SERVICE_PORT=3005
REVIEW_SERVICE_PORT=3006
BLOG_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008

# JWT
JWT_SECRET=camstore_jwt_secret_2026_change_me
JWT_EXPIRES_IN=7d

# Email / password reset
MAIL_APP_NAME=CamStore
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@camstore.local
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Social login
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_GRAPH_VERSION=v25.0
VITE_GOOGLE_CLIENT_ID=your_google_oauth_web_client_id
VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_FACEBOOK_API_VERSION=v25.0

# Development admin bootstrap
BOOTSTRAP_ADMIN_EMAIL=admin@camstore.local
BOOTSTRAP_ADMIN_PASSWORD=Admin@123456
BOOTSTRAP_ADMIN_FIRST_NAME=CamStore
BOOTSTRAP_ADMIN_LAST_NAME=Admin

# Internal service calls
INTERNAL_API_KEY=camstore_internal_api_key_2026_change_me
USER_SERVICE_URL=http://localhost:3001
PRODUCT_SERVICE_URL=http://localhost:3002
CART_SERVICE_URL=http://localhost:3003
ORDER_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005
REVIEW_SERVICE_URL=http://localhost:3006
BLOG_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008
VITE_NOTIFICATION_SOCKET_URL=http://localhost:3008
VITE_NOTIFICATION_SOCKET_PATH=/ws/notifications

# API Gateway aggregation
GATEWAY_REQUEST_TIMEOUT_MS=15000
GATEWAY_AGGREGATE_PAGE_SIZE=100
GATEWAY_AGGREGATE_MAX_PAGES=50
UPLOAD_MAX_FILE_SIZE=5242880

# Unpaid online payment reminder job
UNPAID_PAYMENT_REMINDER_HOURS=12
UNPAID_PAYMENT_EXPIRY_HOURS=24
UNPAID_PAYMENT_JOB_INTERVAL_MS=300000
UNPAID_PAYMENT_JOB_ENABLED=true

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
ALLOW_LOCAL_UPLOADS=true
PUBLIC_UPLOAD_BASE_URL=http://localhost:3000

# VNPay sandbox
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return
VNPAY_IPN_URL=http://localhost:3005/api/payments/vnpay/ipn

# MoMo sandbox
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/payment/momo-return
MOMO_IPN_URL=http://localhost:3005/api/payments/momo/ipn
